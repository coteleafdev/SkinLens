FROM python:3.10-slim

# 작업 디렉토리 설정
WORKDIR /app

# 시스템 패키지 설치
RUN apt-get update && apt-get install -y \
    git \
    wget \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Python 패키지 복사
COPY requirements.txt .

# Python 패키지 설치
RUN pip install --no-cache-dir -r requirements.txt

# 프로젝트 파일 복사
COPY . .

# 작업 디렉토리 생성
RUN mkdir -p jobs results logs

# 환경변수 설정
ENV PYTHONPATH=/app
ENV SERVER_HOST=0.0.0.0
ENV SERVER_PORT=8000
ENV ENGINE_SERVER_URL=http://skinlens-engine:8001
ENV CORS_ORIGINS=http://localhost:3000,http://localhost:8000
ENV ENABLE_GPU=true

# 포트 노출
EXPOSE 8000

# 웹서버 실행
CMD ["python", "-m", "src.server.server"]
