# SkinLens Docker 환경변수 예제
# 이 파일을 복사하여 .env로 사용하세요

# 보안 설정
JWT_SECRET_KEY=your-secret-key-change-in-production

# Gemini API
GEMINI_API_KEY=your-gemini-api-key

# GPU 설정 (GPU가 없는 환경에서는 false로 설정)
ENABLE_GPU=true

# CORS 허용 오리진 (콤마로 구분)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# 데이터베이스 경로
SKIN_ANALYSIS_DB=/app/data/skin_analysis.db

# 엔진 서버 설정
ENGINE_SERVER_HOST=0.0.0.0
ENGINE_SERVER_PORT=8001

# 웹서버 설정
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
ENGINE_SERVER_URL=http://skinlens-engine:8001
