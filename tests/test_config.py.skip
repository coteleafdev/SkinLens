    def test_config_json_exists(self):
        """config.json 파일 존재 테스트"""
        assert TEST_CONFIG_PATH.exists(), f"config.json not found at {TEST_CONFIG_PATH}"

    def test_config_json_valid_json(self):
        """config.json 유효한 JSON 테스트"""
        try:
            with open(TEST_CONFIG_PATH, "r", encoding="utf-8") as f:
                json.load(f)
        except json.JSONDecodeError as e:
            pytest.fail(f"config.json is not valid JSON: {e}")

    def test_config_version(self):
        """config 버전 테스트"""
        config = load_test_config()
        assert "version" in config
        assert isinstance(config["version"], str)
        # 버전 형식 확인 (예: "3.6")
        version_parts = config["version"].split(".")
        assert len(version_parts) >= 2
        assert all(part.isdigit() for part in version_parts)

    def test_config_completeness(self):
        """config.json 필수 섹션 존재 테스트"""
        config = load_test_config()

        required_sections = [
            "server",
            "database",
            "jwt",
            "environment",
            "llm",
            "timeouts",
            "device"
        ]

        for section in required_sections:
            assert section in config, f"Required section '{section}' not found in config.json"

    def test_weights_consistency(self):
        """weights 가중치 키 일관성 테스트"""
        from src.skin.compose.score_composition import _get_weights

        config = load_test_config()
        config_weights = config.get("weights", {})
        fallback_weights = _get_weights()

        # 두 가중치 딕셔너리의 키가 일치하는지 확인
        config_keys = set(config_weights.keys())
        fallback_keys = set(fallback_weights.keys())

        # 메타데이터 키 제외 (_로 시작하는 키)
        config_keys = {k for k in config_keys if not k.startswith('_')}
        fallback_keys = {k for k in fallback_keys if not k.startswith('_')}

        assert config_keys == fallback_keys, (
            f"weights 키 불일치: config.json={config_keys}, fallback={fallback_keys}. "
            "두 곳의 가중치 키를 동기화해야 합니다."
        )

        # skin_type_score 키가 존재하는지 확인 (hydration_score가 아님)
        assert "skin_type_score" in config_weights, "config.json weights에 skin_type_score 키가 없습니다"
        assert "skin_type_score" in fallback_weights, "fallback weights에 skin_type_score 키가 없습니다"
        assert "hydration_score" not in config_weights, "config.json weights에 hydration_score 키가 있습니다 (skin_type_score로 변경 필요)"
        assert "hydration_score" not in fallback_weights, "fallback weights에 hydration_score 키가 있습니다 (skin_type_score로 변경 필요)"

        # 가중치 합이 1.0에 가까운지 확인
        config_sum = sum(config_weights.values())
        fallback_sum = sum(fallback_weights.values())

        assert abs(config_sum - 1.0) < 0.01, f"config.json weights 합이 1.0이 아닙니다: {config_sum}"
        assert abs(fallback_sum - 1.0) < 0.01, f"fallback weights 합이 1.0이 아닙니다: {fallback_sum}"

    def test_measurements_metadata_structure(self):
        """측정항목 메타데이터 구조 테스트"""
        from src.prescription.prescription_calculator import get_all_measurements, get_measurement_metadata

        config = load_test_config()
        prescription_config = config.get("prescription", {})
        measurements = prescription_config.get("measurements", {})

        # measurements 섹션 존재 확인
        assert "measurements" in prescription_config, "config.json에 measurements 섹션이 없습니다"

        # 필수 측정항목 존재 확인 (17개)
        required_measurements = [
            "dullness_score", "eye_wrinkle_score", "nasolabial_wrinkle_score",
            "fine_deep_wrinkle_score", "jawline_blur_score", "melasma_score",
            "freckle_score", "post_acne_pigment_score", "redness_score",
            "post_inflammatory_erythema_score", "pore_size_score", "pore_sagging_score",
            "roughness_score", "skin_tone_score", "uneven_tone_score",
            "cheek_sagging_score", "acne_score", "skin_type_score"
        ]

        for measurement in required_measurements:
            assert measurement in measurements, f"측정항목 '{measurement}'이 measurements에 없습니다"

        # 각 측정항목 메타데이터 구조 확인
        for measurement_key, metadata in measurements.items():
            if measurement_key.startswith("_"):
                continue  # _note 등 주석 필드 건너뜀

            assert "name_ko" in metadata, f"{measurement_key}에 name_ko가 없습니다"
            assert "name_en" in metadata, f"{measurement_key}에 name_en이 없습니다"
            assert "category" in metadata, f"{measurement_key}에 category가 없습니다"
            assert "description" in metadata, f"{measurement_key}에 description이 없습니다"
            assert "breakpoints" in metadata, f"{measurement_key}에 breakpoints가 없습니다"

        # get_all_measurements 함수 테스트
        all_measurements = get_all_measurements()
        assert len(all_measurements) >= 17, f"측정항목이 17개 미만입니다: {len(all_measurements)}"

        # get_measurement_metadata 함수 테스트
        melasma_meta = get_measurement_metadata("melasma_score")
        assert melasma_meta is not None, "melasma_score 메타데이터를 로드하지 못했습니다"
        assert melasma_meta["name_ko"] == "기미", "melasma_score name_ko가 올바르지 않습니다"
        assert melasma_meta["category"] == "pigmentation", "melasma_score category가 올바르지 않습니다"
        assert "breakpoints" in melasma_meta, "melasma_score에 breakpoints가 없습니다"

    def test_orthogonal_categories_structure(self):
        """직교 항목 메타데이터 구조 테스트"""
        from src.skin.compose.score_composition import get_all_orthogonal_categories, get_orthogonal_category_metadata

        config = load_test_config()
        prescription_config = config.get("prescription", {})
        orthogonal_categories = prescription_config.get("orthogonal_categories", {})

        # orthogonal_categories 섹션 존재 확인
        assert "orthogonal_categories" in prescription_config, "config.json에 orthogonal_categories 섹션이 없습니다"

        # 필수 직교 항목 존재 확인 (10개)
        required_categories = [
            "pigmentation_cov", "spot_density", "diffuse_redness", "focal_lesion",
            "pore_score", "wrinkle_score", "roughness_score", "tone_score",
            "elasticity_score", "skin_type_score"
        ]

        for category in required_categories:
            assert category in orthogonal_categories, f"직교 항목 '{category}'이 orthogonal_categories에 없습니다"

        # 각 직교 항목 메타데이터 구조 확인
        for category_key, metadata in orthogonal_categories.items():
            if category_key.startswith("_"):
            if not isinstance(metadata, dict):
                continue  # 문자열 값 건너뜀
                continue  # _note 등 주석 필드 건너뜀

            assert "name_ko" in metadata, f"{category_key}에 name_ko가 없습니다"
            assert "name_en" in metadata, f"{category_key}에 name_en이 없습니다"
            assert "weight" in metadata, f"{category_key}에 weight가 없습니다"
            assert "source_measurements" in metadata, f"{category_key}에 source_measurements가 없습니다"
            assert "composition_function" in metadata, f"{category_key}에 composition_function이 없습니다"

        # 가중치 합이 1.0에 가까운지 확인
        total_weight = sum(metadata.get("weight", 0.0) for metadata in orthogonal_categories.values() 
                          if isinstance(metadata, dict) and not metadata.get("_note"))
        assert abs(total_weight - 1.0) < 0.01, f"직교 항목 가중치 합이 1.0이 아닙니다: {total_weight}"

        # get_all_orthogonal_categories 함수 테스트
        all_categories = get_all_orthogonal_categories()
        assert len(all_categories) >= 10, f"직교 항목이 10개 미만입니다: {len(all_categories)}"

        # get_orthogonal_category_metadata 함수 테스트
        pigmentation_meta = get_orthogonal_category_metadata("pigmentation_cov")
        assert pigmentation_meta is not None, "pigmentation_cov 메타데이터를 로드하지 못했습니다"
        assert pigmentation_meta["name_ko"] == "색소침착 커버리지", "pigmentation_cov name_ko가 올바르지 않습니다"
        assert pigmentation_meta["weight"] == 0.120, "pigmentation_cov weight가 올바르지 않습니다"
        assert "melasma_score" in pigmentation_meta["source_measurements"], "pigmentation_cov source_measurements에 melasma_score가 없습니다"

    def test_categories_structure(self):
        """카테고리 메타데이터 구조 테스트"""
        from src.prescription.prescription_calculator import get_all_categories, get_category_metadata, get_measurements_by_category

        config = load_test_config()
        prescription_config = config.get("prescription", {})
        categories = prescription_config.get("categories", {})

        # categories 섹션 존재 확인
        assert "categories" in prescription_config, "config.json에 categories 섹션이 없습니다"

        # 필수 카테고리 존재 확인 (9개)
        required_categories = [
            "pigmentation", "wrinkle", "redness", "pore", "texture",
            "tone", "elasticity", "acne", "skin_type"
        ]

        for category in required_categories:
            assert category in categories, f"카테고리 '{category}'이 categories에 없습니다"

        # 각 카테고리 메타데이터 구조 확인
        for category_key, metadata in categories.items():
            if category_key.startswith("_"):
                continue  # _note 등 주석 필드 건너뜀

            assert "name_ko" in metadata, f"{category_key}에 name_ko가 없습니다"
            assert "name_en" in metadata, f"{category_key}에 name_en이 없습니다"
            assert "description" in metadata, f"{category_key}에 description이 없습니다"
            assert "measurements" in metadata, f"{category_key}에 measurements가 없습니다"
            assert "mix_codes" in metadata, f"{category_key}에 mix_codes가 없습니다"
            assert "orthogonal_categories" in metadata, f"{category_key}에 orthogonal_categories가 없습니다"

        # get_all_categories 함수 테스트
        all_categories = get_all_categories()
        assert len(all_categories) >= 9, f"카테고리가 9개 미만입니다: {len(all_categories)}"

        # get_category_metadata 함수 테스트
        pigmentation_meta = get_category_metadata("pigmentation")
        assert pigmentation_meta is not None, "pigmentation 카테고리 메타데이터를 로드하지 못했습니다"
        assert pigmentation_meta["name_ko"] == "색소", "pigmentation name_ko가 올바르지 않습니다"
        assert "melasma_score" in pigmentation_meta["measurements"], "pigmentation measurements에 melasma_score가 없습니다"
        assert "M06" in pigmentation_meta["mix_codes"], "pigmentation mix_codes에 M06가 없습니다"

        # get_measurements_by_category 함수 테스트
        pigmentation_measurements = get_measurements_by_category("pigmentation")
        assert len(pigmentation_measurements) >= 3, f"pigmentation 측정항목이 3개 미만입니다: {len(pigmentation_measurements)}"
        assert "melasma_score" in pigmentation_measurements, "pigmentation 측정항목에 melasma_score가 없습니다"

    def test_gui_table_helpers(self):
        """GUI 테이블 동적 생성 헬퍼 함수 테스트"""
        from src.prescription.prescription_calculator import get_measurement_display_names, get_ordered_measurement_keys

        # get_measurement_display_names 테스트
        display_names = get_measurement_display_names()
        assert len(display_names) >= 17, f"디스플레이 이름이 17개 미만입니다: {len(display_names)}"
        assert "melasma_score" in display_names, "melasma_score 디스플레이 이름이 없습니다"
        assert display_names["melasma_score"] == "기미", "melasma_score 디스플레이 이름이 올바르지 않습니다"

        # get_ordered_measurement_keys 테스트
        ordered_keys = get_ordered_measurement_keys()
        assert len(ordered_keys) >= 17, f"정렬된 측정항목이 17개 미만입니다: {len(ordered_keys)}"

        # 카테고리 순서 확인 (pigmentation 먼저)
        first_keys = ordered_keys[:3]
        assert "melasma_score" in first_keys, "pigmentation 측정항목이 먼저 나오지 않습니다"
        assert "freckle_score" in first_keys, "pigmentation 측정항목이 먼저 나오지 않습니다"
        assert "post_acne_pigment_score" in first_keys, "pigmentation 측정항목이 먼저 나오지 않습니다"

    def test_analyzers_config_structure(self):
        """Analyzer 레지스트리 구조 테스트"""
        config = load_test_config()
        prescription_config = config.get("prescription", {})
        analyzers = prescription_config.get("analyzers", {})

        # analyzers 섹션 존재 확인
        assert "analyzers" in prescription_config, "config.json에 analyzers 섹션이 없습니다"

        # 필수 분석기 존재 확인 (7개)
        required_analyzers = [
            "pigmentation_v1", "pigmentation_v2", "redness_v1",
            "pore_v1", "wrinkle_v1", "tone_elasticity_v1", "acne_v1"
        ]

        for analyzer in required_analyzers:
            assert analyzer in analyzers, f"분석기 '{analyzer}'이 analyzers에 없습니다"

        # 각 분석기 메타데이터 구조 확인
        for analyzer_key, metadata in analyzers.items():
            if analyzer_key.startswith("_"):
                continue  # _note 등 주석 필드 건너뜀

            assert "class" in metadata, f"{analyzer_key}에 class가 없습니다"
            assert "module" in metadata, f"{analyzer_key}에 module이 없습니다"
            assert "aliases" in metadata, f"{analyzer_key}에 aliases가 없습니다"
            assert "enabled" in metadata, f"{analyzer_key}에 enabled가 없습니다"

        # pigmentation_v1 구조 확인
        pig_v1 = analyzers.get("pigmentation_v1")
        assert pig_v1["class"] == "PigmentationAnalyzerV1", "pigmentation_v1 class가 올바르지 않습니다"
        assert pig_v1["module"] == "src.skin.analyzers.strategies.pigmentation_analyzer", "pigmentation_v1 module이 올바르지 않습니다"
        assert "pigmentation" in pig_v1["aliases"], "pigmentation_v1 aliases에 pigmentation이 없습니다"
        assert pig_v1["enabled"] == True, "pigmentation_v1 enabled가 True가 아닙니다"


if __name__ == "__main__":
    pytest.main([__file__, "-v"])
