# MANIFEST.in for SkinLens v1.0
# Include non-Python files in the distribution

# Configuration files
include config/*.json
include config/*.secrets.json

# Documentation
include README.md
include pyproject.toml
include requirements*.txt
include pytest.ini

# Locale files
recursive-include locales *.json *.po *.mo

# Package data (from src/)
recursive-include src *.json *.md *.txt

# Test data (if any)
recursive-include tests *.json *.txt *.csv

# Exclude development and runtime files
exclude .gitignore
exclude .pytest_cache
exclude __pycache__
exclude *.pyc
exclude *.db
exclude *.log
exclude *.xlsx
exclude *.egg-info
exclude dist
exclude build
exclude .venv
